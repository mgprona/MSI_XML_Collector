<Window x:Class="Manager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="MSI XML Manager"
        Height="700" Width="1200"
        MinHeight="500" MinWidth="800">
    <DockPanel>

        <!-- ── Toolbar ── -->
        <ToolBar DockPanel.Dock="Top" ToolBarTray.IsLocked="True">
            <Button x:Name="btnOpenDb" Content="เปิด DB..." Padding="10,3"
                    Click="BtnOpenDb_Click"/>
            <Separator/>
            <Button x:Name="btnMerge" Content="Merge จาก USB..." Padding="10,3"
                    Click="BtnMerge_Click"/>
            <Separator/>
            <Button x:Name="btnExport" Content="Export CSV..." Padding="10,3"
                    Click="BtnExport_Click"/>
            <Separator/>
            <TextBlock x:Name="txtDbPath" VerticalAlignment="Center"
                       Foreground="Gray" Text="(ยังไม่ได้เปิด DB)"
                       MaxWidth="600" TextTrimming="CharacterEllipsis" Margin="4,0"/>
        </ToolBar>

        <!-- ── Status Bar ── -->
        <StatusBar DockPanel.Dock="Bottom">
            <StatusBarItem>
                <TextBlock x:Name="txtStatus" Text="พร้อม"/>
            </StatusBarItem>
            <StatusBarItem>
                <ProgressBar x:Name="progressStatus"
                             Width="140" Height="14"
                             Visibility="Collapsed"
                             IsIndeterminate="True"/>
            </StatusBarItem>
            <Separator/>
            <StatusBarItem>
                <TextBlock x:Name="txtCount"/>
            </StatusBarItem>
        </StatusBar>

        <!-- ── Main Content ── -->
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Filter Bar -->
            <Border Grid.Row="0" Background="#F0F0F0" BorderBrush="#DDDDDD"
                    BorderThickness="0,0,0,1" Padding="6,4">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="จังหวัด:" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <ComboBox x:Name="cbProvince" Width="130" VerticalContentAlignment="Center"
                              SelectionChanged="Filter_SelectionChanged"/>

                    <TextBlock Text="เครื่อง:" VerticalAlignment="Center" Margin="12,0,4,0"/>
                    <ComboBox x:Name="cbMachine" Width="130" VerticalContentAlignment="Center"
                              SelectionChanged="Filter_SelectionChanged"/>

                    <TextBlock Text="ค้นหา:" VerticalAlignment="Center" Margin="12,0,4,0"/>
                    <TextBox x:Name="txtSearch" Width="200" VerticalContentAlignment="Center"
                             TextChanged="Filter_TextChanged"/>

                    <CheckBox x:Name="chkConflictOnly" Content="เฉพาะไฟล์ซ้ำ"
                              VerticalAlignment="Center" Margin="12,0,0,0"
                              Checked="Filter_CheckChanged" Unchecked="Filter_CheckChanged"/>

                    <Button Content="ล้าง" Margin="10,0,0,0" Padding="8,2"
                            Click="BtnClear_Click"/>
                </StackPanel>
            </Border>

            <!-- Data + Detail split -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="4"/>
                    <ColumnDefinition Width="340" MinWidth="220"/>
                </Grid.ColumnDefinitions>

                <!-- DataGrid -->
                <DataGrid x:Name="dgFiles" Grid.Column="0"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          SelectionMode="Single"
                          CanUserSortColumns="True"
                          GridLinesVisibility="Horizontal"
                          AlternatingRowBackground="#FAFAFA"
                          SelectionChanged="DgFiles_SelectionChanged">

                    <DataGrid.RowStyle>
                        <Style TargetType="DataGridRow">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsConflict}" Value="True">
                                    <Setter Property="Background" Value="#FFF3CD"/>
                                    <Setter Property="ToolTip"    Value="เลขที่สอบสวนซ้ำกับไฟล์อื่น (ไฟล์ซ้ำ)"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>

                    <DataGrid.Columns>
                        <DataGridTextColumn Header="เลขที่สอบสวน"
                                            Binding="{Binding SurveyJobNo}"   Width="130"/>
                        <DataGridTextColumn Header="ชื่อเจ้าของ"
                                            Binding="{Binding OwnerName}"      Width="180"/>
                        <DataGridTextColumn Header="วันที่"
                                            Binding="{Binding QueueDateDisplay}" Width="100"/>
                        <DataGridTextColumn Header="จังหวัด"
                                            Binding="{Binding ProvinceName}"   Width="110"/>
                        <DataGridTextColumn Header="เครื่อง"
                                            Binding="{Binding MachineName}"    Width="110"/>
                        <DataGridTextColumn Header="รูปแบบ"
                                            Binding="{Binding EncryptedDisplay}" Width="80"/>
                        <DataGridTextColumn Header="วันที่เก็บ"
                                            Binding="{Binding CollectedAtDisplay}" Width="140"/>
                    </DataGrid.Columns>
                </DataGrid>

                <!-- Splitter -->
                <GridSplitter Grid.Column="1" Width="4"
                              HorizontalAlignment="Stretch"
                              Background="#CCCCCC" ResizeBehavior="PreviousAndNext"/>

                <!-- Detail Panel -->
                <DockPanel Grid.Column="2" LastChildFill="True">

                    <GroupBox DockPanel.Dock="Top" Header="รายละเอียด"
                              Margin="4,4,4,2">
                        <TextBox x:Name="txtDetail"
                                 IsReadOnly="True" AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 Background="Transparent" BorderThickness="0"
                                 FontFamily="Consolas" FontSize="11"
                                 Height="230"
                                 VerticalScrollBarVisibility="Auto"
                                 Padding="4"/>
                    </GroupBox>

                    <GroupBox Header="เนื้อหาไฟล์" Margin="4,2,4,4">
                        <TextBox x:Name="txtXmlContent"
                                 IsReadOnly="True" AcceptsReturn="True"
                                 TextWrapping="NoWrap"
                                 HorizontalScrollBarVisibility="Auto"
                                 VerticalScrollBarVisibility="Auto"
                                 FontFamily="Consolas" FontSize="10"
                                 Padding="4"/>
                    </GroupBox>
                </DockPanel>
            </Grid>
        </Grid>
    </DockPanel>
</Window>
